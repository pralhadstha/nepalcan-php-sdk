{
    "name": "pralhadstha/nepal-can-php-sdk",
    "description": "PHP SDK for Nepal Can Move (NCM) shipping and courier API - order creation, tracking, webhooks, COD, and delivery management for Nepal",
    "type": "library",
    "license": "MIT",
    "homepage": "https://github.com/pralhadstha/nepal-can-php-sdk",
    "keywords": [
        "ncm",
        "nepal-can-move",
        "shipping",
        "logistics",
        "nepal",
        "php-sdk",
        "courier",
        "delivery",
        "cod",
        "cash-on-delivery",
        "webhook",
        "tracking",
        "ecommerce",
        "api-client",
        "guzzle"
    ],
    "authors": [
        {
            "name": "Pralhad Shrestha",
            "email": "pralhadstha@gmail.com",
            "role": "Developer"
        }
    ],
    "support": {
        "issues": "https://github.com/pralhadstha/nepal-can-php-sdk/issues",
        "source": "https://github.com/pralhadstha/nepal-can-php-sdk"
    },
    "require": {
        "php": "^8.1",
        "guzzlehttp/guzzle": "^7.0"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.0",
        "phpunit/phpunit": "^10.0"
    },
    "scripts": {
        "cs-fix": "php-cs-fixer fix",
        "cs-check": "php-cs-fixer fix --dry-run --diff"
    },
    "autoload": {
        "psr-4": {
            "OmniCargo\\NepalCan\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "OmniCargo\\NepalCan\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
