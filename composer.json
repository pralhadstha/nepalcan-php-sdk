{
    "name": "pralhadstha/nepal-can-php-sdk",
    "description": "PHP SDK for Nepal Can Move (NCM) shipping API",
    "type": "library",
    "license": "MIT",
    "keywords": ["ncm", "nepal-can-move", "shipping", "logistics", "nepal", "php-sdk"],
    "require": {
        "php": "^8.1",
        "guzzlehttp/guzzle": "^7.0"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.0",
        "phpunit/phpunit": "^10.0"
    },
    "scripts": {
        "cs-fix": "php-cs-fixer fix",
        "cs-check": "php-cs-fixer fix --dry-run --diff"
    },
    "autoload": {
        "psr-4": {
            "OmniCargo\\NepalCan\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "OmniCargo\\NepalCan\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
